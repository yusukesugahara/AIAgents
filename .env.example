# 実行環境名。development / production などを指定します。
APP_ENV=development

# API の待受けポートです。
APP_PORT=4000

# API の Bearer token。本番環境では必須です。
API_ACCESS_TOKEN=

# サーバー側のタイムゾーンです。
APP_TIMEZONE=Asia/Tokyo

# ログ出力レベル。必要に応じて debug/info/warn/error を指定します。
LOG_LEVEL=info

# ホスト上のAPIやMigrationコマンドが使うDB接続文字列です。
# Docker Compose内ではcompose.yamlが接続先をpostgres:5432へ自動で上書きします。
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ai_agents

# Google OAuth クライアント ID。
GOOGLE_CLIENT_ID=

# Google OAuth クライアントシークレット。
GOOGLE_CLIENT_SECRET=

# Google OAuth のリダイレクト URI。本番・共有環境ではHTTPSを使用してください。
# HTTPはlocalhost、127.0.0.1、::1だけで利用できます。
GOOGLE_REDIRECT_URI=http://localhost:4000/auth/google/callback

# Refresh TokenのAES-256-GCM暗号化に使う、32 byte Base64鍵です。
# `openssl rand -base64 32` などで生成してください。本番では必須です。
TOKEN_ENCRYPTION_KEY=

# OpenAI API キーです。Bunは.envを自動読込しないため、実行時はOS／CIの環境変数として渡してください。
OPENAI_API_KEY=

# 就活メール解析Agentが使うモデル名。Worker起動時に必須です。
OPENAI_ANALYSIS_MODEL=

# 返信生成用に使うモデル名。PR-10でAgentへ接続します。
OPENAI_REPLY_MODEL=

# Gmail をポーリングする間隔（秒）。
GMAIL_POLL_INTERVAL_SECONDS=300

# Gmail の1回のポーリングで確認する最大メール件数（1〜100）。
GMAIL_POLL_MAX_RESULTS=50

# Gmail 取得時の検索クエリ（例）。
GMAIL_LOOKBACK_QUERY=in:inbox newer_than:1d

# エージェント実行時の最大試行回数（初回実行を含む）。
# 既定では再試行の待機時間は 1 秒、2 秒です（合計 3 試行）。
AGENT_JOB_MAX_ATTEMPTS=3

# エージェントジョブのロックタイムアウト秒数。
AGENT_JOB_LOCK_TIMEOUT_SECONDS=60

# Job を取得するポーリング間隔（ミリ秒）。
AGENT_JOB_POLL_INTERVAL_MS=250

# Job リースを更新する間隔（ミリ秒）。ロックタイムアウトより短くしてください。
AGENT_JOB_LEASE_HEARTBEAT_MS=15000
