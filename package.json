{
  "name": "ai-agents",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "agents/*",
    "packages/*"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "bun test apps agents packages",
    "db:generate": "bun run --filter @ai-agents/database db:generate",
    "db:migrate": "bun run --filter @ai-agents/database db:migrate",
    "db:test-migrate": "bun run --filter @ai-agents/database db:test-migrate",
    "test:integration:database": "INTEGRATION_TESTS=1 DATABASE_URL=postgres://postgres:postgres@localhost:5432/ai_agents bun test packages/database/src/integration.test.ts",
    "test:integration:docker": "DOCKER_INTEGRATION_TESTS=1 bun test packages/database/src/compose.integration.test.ts",
    "compose:up": "docker compose up --build",
    "compose:down": "docker compose down"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@types/bun": "^1.3.14",
    "typescript": "^5.9.3"
  }
}
